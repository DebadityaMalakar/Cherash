# cherash:strict

class Node:
    def __init__(self, value: int):
        self.value = value
        self.next = None

class LinkedList:
    def __init__(self):
        self.head = None
        self.size = 0

    def push(self, value: int):
        node = Node(value)
        node.next = self.head
        self.head = node
        self.size += 1

    def pop(self):
        if self.head is None:
            return None
        val = self.head.value
        self.head = self.head.next
        self.size -= 1
        return val

    def to_list(self):
        result = []
        curr = self.head
        while curr is not None:
            result.append(curr.value)
            curr = curr.next
        return result

ll = LinkedList()
ll.push(1)
ll.push(2)
ll.push(3)

print(ll.to_list())   # [3, 2, 1]
print(ll.pop())        # 3
print(ll.size)         # 2
print(ll.to_list())   # [2, 1]
